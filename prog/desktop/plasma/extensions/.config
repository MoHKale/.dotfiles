;; -*- mode: clojure -*-
(
 ;; Extract extensions but don't overwrite any existing files.
 (:shell {:desc "Installing plasma extensions"
          :cmd "
find ./config -type f |
  while read -r it; do
    dest=\"$XDG_DATA_HOME/knewstuff3/$(basename \"$it\")\"
    if ! [ -e \"$dest\" ]; then
      cp -v \"$it\" \"$dest\"
    fi
  done

find . -mindepth 1 -type f -iname '*.zip' |
  while read -r it; do
    relative_path=\"$XDG_DATA_HOME/$(dirname \"$it\")\"
    mkdir -p \"$relative_path/\"
    unzip -n \"$it\" -d \"$relative_path/\"
  done
"})
)
